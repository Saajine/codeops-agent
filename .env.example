# Anthropic API Key - get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# GitHub Token - for PR review and repository access
GITHUB_TOKEN=your_github_token_here

# CodeOps Configuration
CODEOPS_MODEL=claude-opus-4-6
CODEOPS_MAX_TOKENS=16000
CODEOPS_MAX_ITERATIONS=3
CODEOPS_LOG_LEVEL=INFO

# Storage
CODEOPS_DB_PATH=./codeops_memory.db
CODEOPS_CONTEXT_FILE=./codeops_context.json
